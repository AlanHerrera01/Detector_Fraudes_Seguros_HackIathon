{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cd fraudia-claims && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd fraudia-claims && python -m uvicorn src.app.main:app --host 0.0.0.0 --port $PORT"
  }
}
