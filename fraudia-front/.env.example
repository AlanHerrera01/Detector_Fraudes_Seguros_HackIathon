# ============================================================
# FraudIA Frontend - variables de entorno de Vite
# ============================================================
# Uso:
# 1. Copia este archivo como .env dentro de fraudia-front/
#      copy .env.example .env
# 2. Ajusta la URL si el backend corre en otro host o puerto.
# 3. Las variables expuestas al frontend deben iniciar con VITE_.

# URL base del backend FastAPI.
VITE_API_BASE_URL=http://127.0.0.1:8000

# API key opcional si en algun momento se protege el backend.
# Actualmente puede quedar vacia.
VITE_API_KEY=

# true: usa datos simulados en frontend y no llama al backend.
# false: consume la API real de fraudia-claims.
VITE_USE_MOCK=false
