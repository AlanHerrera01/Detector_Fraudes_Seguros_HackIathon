# ============================================================
# FraudIA Claims - variables de entorno del BACKEND
# ============================================================
# Uso:
# 1. Copia este archivo como .env dentro de fraudia-claims/
#      copy .env.example .env
# 2. Reemplaza solo los valores necesarios.
# 3. Nunca subas .env al repositorio: ahi van API keys y passwords reales.
#
# Booleanos aceptados por el backend:
# - true / false
# - 1 / 0
# - yes / no
#
# Si un proveedor IA no tiene credenciales reales, el backend no se cae:
# devuelve un mensaje claro o puedes usar AI_PROVIDER=local.


# ============================================================
# Proveedor IA por defecto
# ============================================================
# Opciones soportadas:
# - gemini: usa Google Gemini.
# - openai: usa OpenAI Responses API.
# - github: usa GitHub Models.
# - local: usa respuesta local de respaldo, sin internet ni credenciales.
AI_PROVIDER=gemini


# ============================================================
# Google Gemini
# ============================================================
# API key de Google AI Studio / Gemini.
# Deja el placeholder si no usaras Gemini.
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo Gemini usado por el agente conversacional.
GEMINI_MODEL=gemini-2.5-flash

# Tiempo maximo de espera por respuesta, en segundos.
GEMINI_TIMEOUT_SECONDS=8

# Verificacion SSL. En local corporativo con certificados/proxy puede requerir false,
# pero en condiciones normales debe quedarse en true.
GEMINI_VERIFY_SSL=true


# ============================================================
# OpenAI
# ============================================================
# API key de OpenAI. Requerida solo si AI_PROVIDER=openai o si se selecciona
# OpenAI desde el frontend.
OPENAI_API_KEY=your_openai_api_key_here

# Modelo de OpenAI. El backend usa Responses API.
OPENAI_MODEL=gpt-5.2

# Tiempo maximo de espera por respuesta, en segundos.
OPENAI_TIMEOUT_SECONDS=45

# Maximo de tokens de salida para la respuesta del agente.
OPENAI_MAX_OUTPUT_TOKENS=1200

# Verificacion SSL para llamadas a OpenAI.
OPENAI_VERIFY_SSL=true

# Endpoint oficial de Responses API.
OPENAI_ENDPOINT=https://api.openai.com/v1/responses


# ============================================================
# GitHub Models
# ============================================================
# Token de GitHub con acceso a GitHub Models.
# Tambien puedes usar GITHUB_TOKEN, pero GITHUB_MODELS_TOKEN tiene prioridad.
GITHUB_MODELS_TOKEN=your_github_models_token_here

# Modelo servido desde GitHub Models.
GITHUB_MODELS_MODEL=openai/gpt-5

# Tiempo maximo de espera por respuesta, en segundos.
GITHUB_MODELS_TIMEOUT_SECONDS=45

# Maximo de tokens de salida para la respuesta del agente.
GITHUB_MODELS_MAX_COMPLETION_TOKENS=1200

# Verificacion SSL para GitHub Models.
GITHUB_MODELS_VERIFY_SSL=true

# Version de API usada en headers de GitHub.
GITHUB_MODELS_API_VERSION=2026-03-10

# Endpoint de inferencia de GitHub Models.
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference/chat/completions


# ============================================================
# Aplicacion y datos
# ============================================================
# Entorno de ejecucion: local, demo, prod, etc.
APP_ENV=local

# CSV base usado cuando no hay base de datos activa.
DEFAULT_DATA_PATH=data/synthetic/siniestros_sinteticos.csv


# ============================================================
# PostgreSQL
# ============================================================
# false: usa CSV/memoria.
# true: intenta conectar PostgreSQL y persistir datasets cargados.
DB_ENABLED=false

# Conexion local por defecto.
DB_HOST=127.0.0.1
DB_PORT=5432

# Base, usuario y password.
DB_NAME=fraudia_claims
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Esquema y tabla donde se guardan los siniestros.
DB_SCHEMA=public
DB_TABLE=siniestros
